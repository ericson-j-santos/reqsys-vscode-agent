FROM python:3.11-slim

LABEL org.opencontainers.image.title="ReqSys VSCode Agent Runtime"
LABEL org.opencontainers.image.description="Runtime container artifact for ReqSys VSCode Agent readiness validation"
LABEL org.opencontainers.image.source="https://github.com/ericson-j-santos/reqsys-vscode-agent"
LABEL org.opencontainers.image.vendor="ReqSys"

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/agent

WORKDIR /app

RUN addgroup --system reqsys && adduser --system --ingroup reqsys reqsys

COPY agent/requirements.txt /app/agent/requirements.txt
RUN python -m pip install --upgrade pip \
    && pip install --no-cache-dir -r /app/agent/requirements.txt

COPY agent /app/agent

USER reqsys

ENTRYPOINT ["python", "-m", "reqsys_agent.cli"]
CMD ["health"]
